{
  "info": {
    "name": "Uniswap V2 Swap API - Sepolia",
    "_postman_id": "00000000-0000-0000-0000-000000000000",
    "description": "Postman collection for testing the ETH->Token swap API on Sepolia.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Buy Tokens (ETH -> Token)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"token_address\": \"{{TOKEN_ADDRESS}}\",\n  \"eth_amount\": \"0.001\"\n}"
        },
        "url": {
          "raw": "http://localhost:3000/api/v1/swap/buy",
          "protocol": "http",
          "host": ["localhost"],
          "port": "3000",
          "path": ["api", "v1", "swap", "buy"]
        }
      },
      "response": []
    },
    {
      "name": "Sell Tokens (Token -> ETH)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"token_address\": \"{{TOKEN_ADDRESS}}\",\n  \"min_eth_out\": \"0\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "http://localhost:3000/api/v1/swap/sell",
          "protocol": "http",
          "host": ["localhost"],
          "port": "3000",
          "path": ["api", "v1", "swap", "sell"]
        }
      },
      "response": []
    },
    {
      "name": "Get Token Balance",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
