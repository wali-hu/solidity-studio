# Ethereum RPC URL (required for Hardhat deployment)
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR-API-KEY

# Etherscan API key (required for contract verification)
ETHERSCAN_API_KEY=YOUR-ETHERSCAN-API-KEY

# Private key for deployment (required for Hardhat deployment to Sepolia)
# IMPORTANT: Never commit this file with real private keys!
OWNER_PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# Owner wallet address (for minting)
OWNER_ADDRESS=0xYOUR_OWNER_WALLET_ADDRESS

# Contract Addresses (add after deployment)
CONTRACT_ADDRESS_ERC721A=0xYOUR_ERC721A_CONTRACT_ADDRESS
CONTRACT_ADDRESS_ERC1155=0xYOUR_ERC1155_CONTRACT_ADDRESS

# New wallet address (for transfers)
NEW_WALLET_ADDRESS=0xYOUR_NEW_WALLET_ADDRESS

# Pinata IPFS Configuration (JWT Authentication)
PINATA_JWT=YOUR_PINATA_JWT_TOKEN

# Enable debug mode for detailed error messages
# DEBUG=true
