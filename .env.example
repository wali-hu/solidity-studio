# Sepolia Testnet Configuration
# Get Sepolia RPC URL from services like Alchemy, Infura, or QuickNode
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_API_KEY

# Private Key of the wallet that will deploy contracts and be the marketplace owner
# IMPORTANT: Never commit your actual private key! Use this .env.example as a template
# Create a .env file (which is gitignored) and paste your actual values there
SEPOLIA_PRIVATE_KEY=your_owner_private_key_here_without_0x_prefix

# Private Key of the seller wallet (mints and lists NFTs, creates auctions)
SELLER_PRIVATE_KEY=your_seller_private_key_here_without_0x_prefix

# Private Keys of the bidder/buyer wallets
# Bidder 1 also acts as the buyer for fixed-price marketplace purchases
BIDDER1_PRIVATE_KEY=your_bidder1_private_key_here_without_0x_prefix

# Bidder 2 (auction bidding)
BIDDER2_PRIVATE_KEY=your_bidder2_private_key_here_without_0x_prefix

# Bidder 3 (auction bidding)
BIDDER3_PRIVATE_KEY=your_bidder3_private_key_here_without_0x_prefix

# Bidder 4 (tests bidding after auction expiry)
BIDDER4_PRIVATE_KEY=your_bidder4_private_key_here_without_0x_prefix

# Pinata Configuration for IPFS Storage
# Get these from https://pinata.cloud after creating an account
PINATA_JWT=your_pinata_jwt_authentication_key_here

# Optional: Etherscan API Key for contract verification
# Get from https://etherscan.io/myapikey
ETHERSCAN_API_KEY=your_etherscan_api_key_here
