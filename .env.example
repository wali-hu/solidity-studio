SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR-API-KEY
PRIVATE_KEY=your-private-key-here
ETHERSCAN_API_KEY=your-etherscan-api-key
REPORT_GAS=false
CONTRACT_ADDRESS=

# Optional: Recipient address for testing interact.js on testnets
# If not set, interact.js will use the second signer from Hardhat accounts
RECIPIENT_ADDRESS=0x79E7165D44D2C1ff314F7D484d516656351605Df

# Pinata IPFS Configuration (JWT Authentication)
PINATA_JWT=your-pinata-jwt-token-here

# Transaction Hash Capture (Optional)
CAPTURE_TX_HASH=false
CAPTURE_OUTPUT_FILE=test-transactions.json
